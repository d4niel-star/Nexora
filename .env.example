# ─────────────────────────────────────────────────────────────────────────────
# Nexora — Environment variables template
# Copy this file to `.env` for local development and set every REQUIRED key.
# Keys marked OPTIONAL are safe to leave blank; the corresponding feature will
# be disabled silently (no-op). Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Core (REQUIRED) ─────────────────────────────────────────────────────────
# Postgres connection string used by Prisma. On Render use the Internal URL.
DATABASE_URL="postgresql://user:password@localhost:5432/nexora_dev"

# Canonical absolute URL of the admin/marketing app. Used for OAuth redirects,
# emails, sitemap, JSON-LD, and webhook callback base.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Apex host of the Nexora SaaS (no scheme). Used by middleware to tell a
# canonical request from a tenant custom domain.
CANONICAL_APP_HOST="localhost"

# Legacy aliases (kept for compatibility with parts of the codebase).
NEXT_PUBLIC_ROOT_DOMAIN="localhost"
NEXT_PUBLIC_APP_DOMAIN="localhost"

# 32-byte hex key used to AES-256-CBC encrypt provider credentials at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ─── AI provider (OPTIONAL — falls back to deterministic mock) ───────────────
# Claude (Anthropic). Without this key the MockBuilderProvider serves
# deterministic content; store creation and every /admin/ai route still works.
ANTHROPIC_API_KEY=""

# Gemini (Google). Same contract: if unset the provider is not registered
# and the system silently falls back to Claude or mock.
GEMINI_API_KEY=""

# Active provider selector. Values: "gemini" | "anthropic" | "mock".
# `AI_PROVIDER` takes precedence; `AI_PROVIDER_DEFAULT` is kept for
# backward compatibility with the prior Anthropic-only setup.
AI_PROVIDER=""
AI_PROVIDER_DEFAULT=""

# Optional override of the Gemini model id. Defaults to "gemini-3.1-pro-preview".
# Use "gemini-3.1-pro-preview-customtools" when tool-use is needed.
AI_MODEL=""

# ─── Transactional email ──────────────────────────────────────────────────────
# Resend (https://resend.com). REQUIRED in production: `getEmailProvider()`
# throws when `NODE_ENV=production` and `RESEND_API_KEY` is unset, instead of
# silently falling back to MockProvider. In development, MockProvider is used
# and emits a loud warn on first call so you never confuse it with a real send.
RESEND_API_KEY=""
# Preferred name. Tenants / deploy tooling that set EMAIL_FROM instead keep
# working — the provider reads RESEND_FROM_EMAIL first, then EMAIL_FROM, and
# only falls back to a safe literal in dev.
RESEND_FROM_EMAIL="Nexora <noreply@example.com>"
EMAIL_FROM=""

# ─── Mercado Pago — platform / billing wallet (REQUIRED for billing) ─────────
# Access token for the platform's OWN MP account (used to charge tenants for
# Nexora plans). Distinct from the tenant OAuth credentials below.
MERCADOPAGO_BILLING_ACCESS_TOKEN=""

# Legacy single-tenant MP access token. Tenants should use OAuth instead; this
# is only used when debugging or for the demo seed.
MERCADOPAGO_ACCESS_TOKEN=""

# ─── Mercado Pago — OAuth (REQUIRED for tenant MP connection) ────────────────
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
# HMAC secret configured in the MP panel for the STOREFRONT payments webhook
# (/api/payments/mercadopago/webhook). Without it the webhook responds 500
# and MP retries indefinitely — set this before go-live.
MP_WEBHOOK_SECRET=""
# HMAC secret configured in the MP panel for the BILLING / subscription
# webhook (/api/webhooks/billing). Optional: when set, the webhook verifies
# the x-signature header; when unset, verification is skipped but the webhook
# still re-fetches each payment from MP's API before mutating any state.
MERCADOPAGO_WEBHOOK_SECRET=""

# ─── Ads platforms OAuth (OPTIONAL — ads integration disabled if unset) ─────
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_DEVELOPER_TOKEN=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
TIKTOK_APP_ID=""
TIKTOK_APP_SECRET=""

# Social login OAuth (OPTIONAL - login/register buttons show a safe message if unset)
# Callback URLs:
#   /api/auth/oauth/google/callback
#   /api/auth/oauth/apple/callback
#   /api/auth/oauth/facebook/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── Analytics (OPTIONAL — tracking disabled if unset) ───────────────────────
# Client-side: Plausible or GA4.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA_ID=""
# Server-side conversion events via GA4 Measurement Protocol.
GA_MEASUREMENT_ID=""
GA_MEASUREMENT_PROTOCOL_SECRET=""

# ─── Cron jobs (REQUIRED to enable abandoned-cart recovery) ──────────────────
# Random shared secret. Cron service (Render/GitHub Actions) must send it as
# header `x-cron-secret`. Without it the cron endpoint responds 503.
CRON_SECRET=""
# Minutes of inactivity before a cart is considered abandoned (default: 120).
ABANDONED_CART_THRESHOLD_MINUTES="120"

# ─── Logistics sandbox (OPTIONAL) ────────────────────────────────────────────
# HMAC secret used by the mock logistics provider for signed callbacks.
MOCK_LOGISTICS_SECRET=""

# ─── Observability (OPTIONAL) ────────────────────────────────────────────────
# Set to "1" to emit verbose audit logs (trace-level) — disable in production.
ENABLE_VERBOSE_AUDIT=""

# Ops allowlist for internal surfaces like /admin/billing/observability.
# Comma-separated emails (case-insensitive). Empty/unset → nobody is ops,
# the surface renders 404 for everyone (fail-closed). This does NOT create
# a DB role; it only scopes visibility of cross-tenant aggregates.
NEXORA_OPS_EMAILS=""

# ─── Runtime (auto) ──────────────────────────────────────────────────────────
# Set by Next/Node. Do not override.
NODE_ENV="development"

# WhatsApp Recovery (app whatsapp-recovery)
# No env nueva requerida. Credenciales WABA (phoneNumberId, accessToken,
# templateName) se configuran por tenant en /admin/apps/whatsapp-recovery/setup
# y se guardan cifradas con ENCRYPTION_KEY (ya definido mas arriba).
# Para envios reales, la tienda necesita una cuenta WhatsApp Business API
# (Meta Cloud) con un template aprobado para marketing.
