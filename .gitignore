# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
*.db

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.tmp-*.out
.tmp-*.err

# env files (can opt-in for committing if needed)
.env
.env.local
.env*
!.env.example

# vercel
.vercel

# IDE / tool metadata
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# User-uploaded store assets (tenant-scoped). Regenerated per-deploy.
# In Render production these must be persisted via Cloudinary/S3 instead.
/public/uploads
tmp.html

# Local verification artifacts (Playwright screenshots)
verification-screenshots/
